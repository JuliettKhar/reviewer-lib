{
  "name": "reviewer-lib",
  "version": "3.2.1",
  "description": "A library for code review using OpenAI API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "reviewer-lib": "bin/reviewer.mjs"
  },
  "keywords": [
    "code",
    "review",
    "openai",
    "api",
    "javascript",
    "typescript"
  ],
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "npx tsc",
    "serve": "npx ts-node src/index.ts",
    "dev": "nodemon src/index.ts",
    "start": "dist/index.js",
    "deploy": "npm publish --non-interactive  --verbose",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke": "node scripts/smoke-test.mjs",
    "review:local": "printf 'function add(a, b) { return a - b; }' | node --env-file=.env review-helper.mjs",
    "review": "npm run build && git diff HEAD | node --env-file=.env bin/reviewer.mjs review",
    "prepublishOnly": "npm run build && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JuliettKhar/reviewer-lib.git"
  },
  "author": "Julia Kharlamova",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "nodemon": "^3.1.4",
    "reviewer-lib-published": "npm:reviewer-lib@^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "openai": "^6.48.0"
  },
  "engines": {
    "node": ">=20"
  }
}

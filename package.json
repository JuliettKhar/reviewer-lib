{
  "name": "reviewer-lib",
  "version": "1.5.0",
  "description": "A library for code review using OpenAI API",
  "main": "dist/index.js",
  "types": "index.d.ts",
  "keywords": [
    "code",
    "review",
    "openai",
    "api",
    "javascript",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npx tsc",
    "serve": "npx ts-node src/index.ts",
    "dev": "nodemon src/index.ts",
    "start": "dist/index.js",
    "deploy": "npm publish --non-interactive  --verbose",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JuliettKhar/reviewer-lib.git"
  },
  "author": "Julia Kharlamova",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.1",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "openai": "^6.48.0"
  }
}
